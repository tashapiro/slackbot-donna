# Donna — environment variables
#
# This is a documented template + checklist. Copy it to a local .env for dev
# (`cp .env.example .env`), and on Render set the ones you use in the dashboard
# (Environment tab) — never commit real secrets. `.env` is gitignored; this file is not.
#
# Legend:  [required] must be set for Donna to boot   [feature] only if you use that feature
# ─────────────────────────────────────────────────────────────────────────────

# ── Slack ────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=            # [required] Bot User OAuth token (xoxb-...)
SLACK_SIGNING_SECRET=       # [required] App signing secret
SLACK_APP_TOKEN=            # [required if SOCKET_MODE=true] App-level token (xapp-...)

# Thread reading needs these Slack scopes (set on the app, not here):
#   channels:history, groups:history, im:history, mpim:history

# ── Runtime & brain selection ────────────────────────────────────────────────
SOCKET_MODE=true            # true = Slack Socket Mode (Render Background Worker)
                            # false = HTTP mode (Render Web Service, binds PORT)
PORT=3000                   # HTTP mode only; Render provides this automatically
AGENT_MODE=true             # true enables the OpenAI intent router for open-ended messages
BRAIN=                      # set to "agentic" to use the Claude brain instead of the router

# ── OpenAI (router brain + task extraction) ──────────────────────────────────
OPENAI_API_KEY=             # [feature] required when BRAIN is unset (router) or for extraction
ROUTER_MODEL=gpt-4o-mini    # optional; intent-classification model
EXTRACT_MODEL=gpt-4o        # optional; action-item extraction model

# ── Anthropic (agentic brain) ────────────────────────────────────────────────
ANTHROPIC_API_KEY=          # [feature] required when BRAIN=agentic
DONNA_MODEL=claude-sonnet-5 # optional; agentic-brain model

# ── Phase 2: memory & client context ─────────────────────────────────────────
# Persistent, scope-isolated memory (personal / business / per-client). Without
# DATABASE_URL, memory is disabled and the bot runs exactly as before.
DATABASE_URL=               # [feature] Postgres connection string (Render Postgres). Enables memory.
DATABASE_SSL=               # optional; "true"/"false" to force SSL. Auto: on unless host is localhost.

# Client registry — the source of truth for clients is your Google Sheet (the "IndieVisual Hub").
# Read with the SAME Google service account as Calendar: share the sheet with the service-account
# email (Viewer is enough). Clients are keyed by the sheet's `id` (CLI-xxx); nicknames are derived
# from the name (corporate suffixes stripped) and email domains from `website`/`email` + Contacts.
# Column headers are auto-detected — only set the COL_* overrides if detection misses a header.
CLIENT_REGISTRY_SHEET_ID=          # [feature] the sheet ID from its URL. Enables the client registry.
CLIENT_REGISTRY_CLIENTS_RANGE=     # optional; the clients tab/range (default: "Clients")
CLIENT_REGISTRY_CONTACTS_RANGE=    # optional; the contacts tab/range for domain detection
                                   #   (default: "Contacts"; set to "" to skip reading Contacts)
# Header overrides (optional — auto-detected from the Clients tab otherwise):
CLIENT_REGISTRY_COL_ID=            # canonical id column (default detects "id")
CLIENT_REGISTRY_COL_NAME=          # client name column (default detects "name")
CLIENT_REGISTRY_COL_STATUS=        # active/archived status (default detects "status")
CLIENT_REGISTRY_COL_ALIASES=       # explicit nicknames column, if you add one (comma-separated)
CLIENT_REGISTRY_COL_WEBSITE=       # website column, for domain detection (default detects "website")
CLIENT_REGISTRY_COL_EMAIL=         # client email column (default detects "email")
CLIENT_REGISTRY_COL_DELETED=       # soft-delete flag; deleted rows are skipped (default "is_deleted")
# Contacts tab header overrides (optional):
CLIENT_REGISTRY_CONTACTS_COL_CLIENTID=  # contact→client link (default detects "client_id")
CLIENT_REGISTRY_CONTACTS_COL_EMAIL=     # contact email (default detects "email")

# ── Asana (tasks/projects) ───────────────────────────────────────────────────
ASANA_API_TOKEN=            # [feature] personal access token
ASANA_WORKSPACE_ID=         # optional; defaults to your first workspace if unset

# ── SavvyCal (scheduling links, booked events, meeting polls) ────────────────
SAVVYCAL_TOKEN=             # [required] API token (app.js checks for it at boot).
                           # Powers both the OpenAI router's link commands and the
                           # agentic brain's scheduling tools (links, events, polls).

# ── Fireflies (meeting notes & transcripts) ──────────────────────────────────
# Powers the agentic brain's Fireflies tools (list meetings, get notes/action items,
# get transcript). Without a key, those tools report "not configured" and the bot runs
# as before. The API key is a Fireflies Pro/Business feature (Fireflies dashboard →
# Settings → Developer/API).
FIREFLIES_API_KEY=          # [feature] Fireflies API key (Bearer token)
FIREFLIES_NOTETAKER_EMAIL=  # optional; the notetaker guest address used to add/remove Fred
                            #   on a calendar event (default: fred@fireflies.ai)

# ── Gmail (email drafts) ─────────────────────────────────────────────────────
# Donna drafts emails into your Gmail (drafts only — she never sends). Uses the SAME Google
# service account as Calendar, via domain-wide delegation to impersonate your mailbox. One-time
# Workspace setup: in Admin console → Security → API controls → Domain-wide delegation, grant the
# service account the scope https://www.googleapis.com/auth/gmail.compose. Without an impersonation
# mailbox the draft_email tool reports "not configured".
GMAIL_IMPERSONATE_EMAIL=    # [feature] mailbox to draft into (falls back to GOOGLE_IMPERSONATE_EMAIL)

# ── Toggl (time tracking) ────────────────────────────────────────────────────
TOGGL_API_TOKEN=            # [feature] API token
TOGGL_WORKSPACE_ID=         # [feature] workspace id

# ── Google Calendar ──────────────────────────────────────────────────────────
# Pick ONE auth method:
#   A) full service-account JSON in one variable, or
#   B) the individual client email + private key.
GOOGLE_SERVICE_ACCOUNT_JSON=  # [feature] (A) the entire service-account JSON, as one string
GOOGLE_CLIENT_EMAIL=          # [feature] (B) service-account client email
GOOGLE_PRIVATE_KEY=           # [feature] (B) private key (literal \n escapes are converted)
GOOGLE_PROJECT_ID=            # optional; (B) GCP project id
GOOGLE_CALENDAR_ID=primary    # optional; which calendar to use (default: primary)
GOOGLE_IMPERSONATE_EMAIL=     # optional; Domain-Wide Delegation — user to impersonate

# ── Peloton (workouts) ───────────────────────────────────────────────────────
# Pick ONE auth method (checked in this priority order):
#   1) Bearer access token   2) manual session id + user id   3) username + password
PELOTON_ACCESS_TOKEN=       # [feature] (1) OAuth2 JWT bearer token (current method)
PELOTON_SESSION_ID=         # [feature] (2) manual session id
PELOTON_USER_ID=            # [feature] (2) manual user id
PELOTON_USERNAME=           # [feature] (3) username (legacy, deprecated by Peloton)
PELOTON_PASSWORD=           # [feature] (3) password (legacy)
