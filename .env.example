# Donna — environment variables
#
# This is a documented template + checklist. Copy it to a local .env for dev
# (`cp .env.example .env`), and on Render set the ones you use in the dashboard
# (Environment tab) — never commit real secrets. `.env` is gitignored; this file is not.
#
# Legend:  [required] must be set for Donna to boot   [feature] only if you use that feature
# ─────────────────────────────────────────────────────────────────────────────

# ── Slack ────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=            # [required] Bot User OAuth token (xoxb-...)
SLACK_SIGNING_SECRET=       # [required] App signing secret
SLACK_APP_TOKEN=            # [required if SOCKET_MODE=true] App-level token (xapp-...)

# Thread reading needs these Slack scopes (set on the app, not here):
#   channels:history, groups:history, im:history, mpim:history

# ── Runtime & brain selection ────────────────────────────────────────────────
SOCKET_MODE=true            # true = Slack Socket Mode (Render Background Worker)
                            # false = HTTP mode (Render Web Service, binds PORT)
PORT=3000                   # HTTP mode only; Render provides this automatically
AGENT_MODE=true             # true enables the OpenAI intent router for open-ended messages
BRAIN=                      # set to "agentic" to use the Claude brain instead of the router

# ── OpenAI (router brain + task extraction) ──────────────────────────────────
OPENAI_API_KEY=             # [feature] required when BRAIN is unset (router) or for extraction
ROUTER_MODEL=gpt-4o-mini    # optional; intent-classification model
EXTRACT_MODEL=gpt-4o        # optional; action-item extraction model

# ── Anthropic (agentic brain) ────────────────────────────────────────────────
ANTHROPIC_API_KEY=          # [feature] required when BRAIN=agentic
DONNA_MODEL=claude-sonnet-5 # optional; agentic-brain model

# ── Asana (tasks/projects) ───────────────────────────────────────────────────
ASANA_API_TOKEN=            # [feature] personal access token
ASANA_WORKSPACE_ID=         # optional; defaults to your first workspace if unset

# ── SavvyCal (scheduling links) ──────────────────────────────────────────────
SAVVYCAL_TOKEN=             # [required] API token (app.js checks for it at boot)

# ── Toggl (time tracking) ────────────────────────────────────────────────────
TOGGL_API_TOKEN=            # [feature] API token
TOGGL_WORKSPACE_ID=         # [feature] workspace id

# ── Google Calendar ──────────────────────────────────────────────────────────
# Pick ONE auth method:
#   A) full service-account JSON in one variable, or
#   B) the individual client email + private key.
GOOGLE_SERVICE_ACCOUNT_JSON=  # [feature] (A) the entire service-account JSON, as one string
GOOGLE_CLIENT_EMAIL=          # [feature] (B) service-account client email
GOOGLE_PRIVATE_KEY=           # [feature] (B) private key (literal \n escapes are converted)
GOOGLE_PROJECT_ID=            # optional; (B) GCP project id
GOOGLE_CALENDAR_ID=primary    # optional; which calendar to use (default: primary)
GOOGLE_IMPERSONATE_EMAIL=     # optional; Domain-Wide Delegation — user to impersonate

# ── Peloton (workouts) ───────────────────────────────────────────────────────
# Pick ONE auth method (checked in this priority order):
#   1) Bearer access token   2) manual session id + user id   3) username + password
PELOTON_ACCESS_TOKEN=       # [feature] (1) OAuth2 JWT bearer token (current method)
PELOTON_SESSION_ID=         # [feature] (2) manual session id
PELOTON_USER_ID=            # [feature] (2) manual user id
PELOTON_USERNAME=           # [feature] (3) username (legacy, deprecated by Peloton)
PELOTON_PASSWORD=           # [feature] (3) password (legacy)
